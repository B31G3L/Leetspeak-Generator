<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 🔐 PERMISSIONS für IME und Data Sharing -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Custom Permission für Leet Data Access -->
    <permission android:name="com.beigel.leetspeak.READ_LEET_DATA"
        android:protectionLevel="signature" />
    <permission android:name="com.beigel.leetspeak.WRITE_LEET_DATA"
        android:protectionLevel="signature" />

    <!-- IME-spezifische Permissions -->
    <uses-permission android:name="android.permission.BIND_INPUT_METHOD"
        tools:ignore="ProtectedPermissions" />

    <application
        android:name=".LeetSpeakApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LeetspeakGenerator"
        tools:targetApi="34">

        <!-- 🏠 MAIN COMPOSE ACTIVITY -->
        <activity
            android:name=".ui.ComposeMainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.LeetspeakGenerator">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ⚙️ SETTINGS ACTIVITY -->
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:label="@string/settings"
            android:theme="@style/Theme.LeetspeakGenerator"
            android:parentActivityName=".ui.ComposeMainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".ui.ComposeMainActivity" />
        </activity>

        <!-- 🎹 LEETSPEAK KEYBOARD SERVICE (MAIN IME) -->
        <service
            android:name=".keyboard.LeetKeyboardService"
            android:exported="true"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:label="@string/leetspeak_keyboard_label">

            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>

            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- 📊 LEET DATA PROVIDER (für App-Keyboard Sync) -->
        <provider
            android:name=".keyboard.data.LeetDataProvider"
            android:authorities="com.beigel.leetspeak.provider"
            android:exported="true"
            android:readPermission="com.beigel.leetspeak.READ_LEET_DATA"
            android:writePermission="com.beigel.leetspeak.WRITE_LEET_DATA"
            android:grantUriPermissions="true">

            <!-- Allow keyboard access without explicit permission -->
            <grant-uri-permission
                android:pathPattern="/favorite_leet" />
            <grant-uri-permission
                android:pathPattern="/all_leets" />
            <grant-uri-permission
                android:pathPattern="/leet_settings" />
        </provider>

        <!-- 📱 WIDGET PROVIDER -->
        <receiver
            android:name=".widget.LeetWidgetProvider"
            android:exported="true"
            android:label="@string/widget_description">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- 🔔 KEYBOARD NOTIFICATION SERVICE (Optional für Statistiken) -->
        <service
            android:name=".keyboard.LeetKeyboardService"
            android:exported="true"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:label="@string/leetspeak_keyboard_label">

            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>

            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

    </application>

</manifest>
