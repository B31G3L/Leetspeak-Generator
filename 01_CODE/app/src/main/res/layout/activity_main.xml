<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorSurface"
            app:titleTextColor="?android:attr/textColorPrimary"
            app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light">

            <!-- Titel in der Toolbar -->
            <TextView
                android:id="@+id/appTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/raleway"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_gravity="start|center_vertical" />

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Input Section - nimmt obere Hälfte ein -->
        <LinearLayout
            android:id="@+id/input_section"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header mit Statistics -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/plaintext_placeholder"
                            android:textSize="14sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:fontFamily="@font/raleway" />

                        <!-- Statistics -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/characterCounter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="12sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:fontFamily="@font/raleway"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="•"
                                android:textSize="12sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/wordCounter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 Wörter"
                                android:textSize="12sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:fontFamily="@font/raleway" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Input Field mit Undo/Redo Buttons -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputPlainText"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:inputType="textMultiLine"
                            android:gravity="top|start"
                            android:background="@android:color/transparent"
                            android:textSize="16sp"
                            android:fontFamily="@font/raleway"
                            android:textColor="?android:attr/textColorPrimary"
                            android:hint="Hier deinen Text eingeben..."
                            android:textColorHint="?android:attr/textColorTertiary"
                            android:layout_above="@+id/undoRedoButtons" />

                        <!-- Undo/Redo Buttons -->
                        <LinearLayout
                            android:id="@+id/undoRedoButtons"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:orientation="horizontal"
                            android:layout_margin="8dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonUndo"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:insetLeft="0dp"
                                android:insetRight="0dp"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:text="↶"
                                android:textSize="16sp"
                                android:textColor="?attr/colorSecondary"
                                android:alpha="0.5"
                                android:enabled="false"
                                android:layout_marginEnd="4dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonRedo"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:insetLeft="0dp"
                                android:insetRight="0dp"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:text="↷"
                                android:textSize="16sp"
                                android:textColor="?attr/colorSecondary"
                                android:alpha="0.5"
                                android:enabled="false" />
                        </LinearLayout>
                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Divider - nur sichtbar wenn Output vorhanden -->
        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorSecondary"
            android:layout_marginHorizontal="16dp"
            android:visibility="gone" />

        <!-- Output Section - nimmt untere Hälfte ein, nur sichtbar wenn Text vorhanden -->
        <LinearLayout
            android:id="@+id/output_section"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header mit Copy Button und Actions -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Leetspeak Übersetzung"
                            android:textSize="14sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:fontFamily="@font/raleway" />

                        <!-- Action Buttons -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonReverse"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:insetLeft="0dp"
                                android:insetRight="0dp"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:text="⇄"
                                android:textSize="14sp"
                                android:textColor="?attr/colorSecondary"
                                android:layout_marginEnd="4dp"
                                android:tooltipText="Reverse Translation" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonCopy"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/copy_text"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:textColor="?attr/colorSecondary"
                                android:fontFamily="@font/raleway"
                                android:textSize="12sp"
                                android:minHeight="0dp"
                                android:paddingVertical="4dp"
                                android:paddingHorizontal="8dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Scrollbarer Output Text mit Live Preview -->
                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <TextView
                            android:id="@+id/outputLeetText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:fontFamily="@font/raleway"
                            android:textColor="?android:attr/textColorPrimary"
                            android:textIsSelectable="true"
                            android:padding="8dp"
                            android:background="?attr/selectableItemBackground" />
                    </ScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Bottom Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Leet Selector Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonLeetSelector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Plain → Simple Leet"
                android:drawableEnd="@drawable/ic_expand_more"
                android:drawablePadding="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:fontFamily="@font/raleway"
                android:textAllCaps="false"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:minHeight="56dp"
                app:strokeColor="?attr/colorSecondary"
                android:textColor="?android:attr/textColorPrimary" />

            <!-- Table Toggle Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonExpandTable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/table_expand"
                android:drawableEnd="@drawable/ic_expand_more"
                android:drawablePadding="8dp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:fontFamily="@font/raleway"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:textColor="?attr/colorSecondary" />

            <!-- Table Container -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tableContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Table Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="?attr/colorSecondary"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/plain"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSecondary"
                            android:fontFamily="@font/raleway"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/leet"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSecondary"
                            android:fontFamily="@font/raleway"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/plain"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSecondary"
                            android:fontFamily="@font/raleway"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/leet"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSecondary"
                            android:fontFamily="@font/raleway"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Scrollbare Tabelle -->
                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxHeight="300dp">

                        <!-- Table Content -->
                        <TableLayout
                            android:id="@+id/leetTable"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:stretchColumns="*">
                            <!-- Table rows will be added dynamically -->
                        </TableLayout>
                    </ScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>