<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorSurface"
            app:titleTextColor="?android:attr/textColorPrimary"
            app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light">

            <!-- Titel in der Toolbar -->
            <TextView
                android:id="@+id/appTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/raleway"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_gravity="start|center_vertical" />

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Input Section - nimmt obere Hälfte ein -->
        <LinearLayout
            android:id="@+id/input_section"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Vereinfachter Header ohne Counter -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Plaintext"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:fontFamily="@font/raleway"
                        android:layout_marginBottom="8dp" />

                    <!-- Input Field ohne Undo/Redo Buttons -->
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputPlainText"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:inputType="textMultiLine"
                        android:gravity="top|start"
                        android:background="@android:color/transparent"
                        android:textSize="18sp"
                        android:fontFamily="@font/raleway"
                        android:textColor="?android:attr/textColorPrimary"
                        android:hint="Hier deinen Text eingeben..."
                        android:textColorHint="?android:attr/textColorTertiary"
                        android:lineSpacingMultiplier="1.2" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Divider - nur sichtbar wenn Output vorhanden -->
        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorSecondary"
            android:layout_marginHorizontal="16dp"
            android:visibility="gone" />

        <!-- Output Section - nimmt untere Hälfte ein, nur sichtbar wenn Text vorhanden -->
        <LinearLayout
            android:id="@+id/output_section"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header mit dynamischem Leet-Namen -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/outputModeTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Simple Leet"
                            android:textSize="14sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:fontFamily="@font/raleway" />

                        <!-- Copy Button als Icon in der rechten Ecke -->
                        <ImageView
                            android:id="@+id/buttonCopy"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_copy"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="4dp"
                            android:contentDescription="@string/copy_text"
                            android:tint="?attr/colorSecondary" />
                    </LinearLayout>

                    <!-- Scrollbarer Output Text mit größerer Schrift -->
                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <TextView
                            android:id="@+id/outputLeetText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="18sp"
                            android:fontFamily="@font/raleway"
                            android:textColor="?android:attr/textColorPrimary"
                            android:textIsSelectable="true"
                            android:padding="8dp"
                            android:background="?attr/selectableItemBackground"
                            android:lineSpacingMultiplier="1.2" />
                    </ScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Bottom Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Leet Selector Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonLeetSelector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Plain → Simple Leet"
                android:drawableEnd="@drawable/ic_expand_more"
                android:drawablePadding="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:fontFamily="@font/raleway"
                android:textAllCaps="false"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:minHeight="56dp"
                app:strokeColor="?attr/colorSecondary"
                android:textColor="?android:attr/textColorPrimary" />

            <!-- Table Toggle Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonExpandTable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/table_expand"
                android:drawableEnd="@drawable/ic_expand_more"
                android:drawablePadding="8dp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:fontFamily="@font/raleway"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:textColor="?attr/colorSecondary" />

            <!-- Table Container -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tableContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Table Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="?attr/colorSecondary"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/plain"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSecondary"
                            android:fontFamily="@font/raleway"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/leet"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSecondary"
                            android:fontFamily="@font/raleway"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/plain"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSecondary"
                            android:fontFamily="@font/raleway"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/leet"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSecondary"
                            android:fontFamily="@font/raleway"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Scrollbare Tabelle -->
                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxHeight="300dp">

                        <!-- Table Content -->
                        <TableLayout
                            android:id="@+id/leetTable"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:stretchColumns="*">
                            <!-- Table rows will be added dynamically -->
                        </TableLayout>
                    </ScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>