<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorSurface"
            app:titleTextColor="?android:attr/textColorPrimary"
            app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light">

            <!-- Titel in der Toolbar -->
            <TextView
                android:id="@+id/appTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/raleway"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_gravity="start|center_vertical" />

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Hauptkarte mit Input/Output -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Card.BottomRounded">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Input Section -->
                <LinearLayout
                    android:id="@+id/input_section"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Input Header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Plaintext"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:fontFamily="@font/raleway"
                        android:layout_marginBottom="8dp" />

                    <!-- Input Field -->
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputPlainText"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:inputType="textMultiLine"
                        android:gravity="top|start"
                        android:background="@android:color/transparent"
                        android:textSize="18sp"
                        android:fontFamily="@font/raleway"
                        android:textColor="?android:attr/textColorPrimary"
                        android:hint="Hier deinen Text eingeben..."
                        android:textColorHint="?android:attr/textColorTertiary"
                        android:lineSpacingMultiplier="1.2" />

                </LinearLayout>

                <!-- Divider - nur sichtbar wenn Output vorhanden -->
                <View
                    android:id="@+id/divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorSecondary"
                    android:layout_marginHorizontal="16dp"
                    android:visibility="gone" />

                <!-- Output Section - nur sichtbar wenn Text vorhanden -->
                <LinearLayout
                    android:id="@+id/output_section"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <!-- Output Header mit Copy Button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/outputModeTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Simple Leet"
                            android:textSize="14sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:fontFamily="@font/raleway" />

                        <!-- Copy Button -->
                        <ImageView
                            android:id="@+id/buttonCopy"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_copy"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="4dp"
                            android:contentDescription="@string/copy_text"
                            android:tint="?attr/colorSecondary" />
                    </LinearLayout>

                    <!-- Scrollbarer Output Text -->
                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <TextView
                            android:id="@+id/outputLeetText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="18sp"
                            android:fontFamily="@font/raleway"
                            android:textColor="?android:attr/textColorPrimary"
                            android:textIsSelectable="true"
                            android:padding="8dp"
                            android:background="?attr/selectableItemBackground"
                            android:lineSpacingMultiplier="1.2" />
                    </ScrollView>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Button-Sektion außerhalb der Karte -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:elevation="2dp">

            <!-- Plain Text Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPlainSelector"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Plain"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:fontFamily="@font/raleway"
                android:textAllCaps="false"
                android:minHeight="48dp"
                app:strokeColor="?attr/colorSecondary"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginEnd="8dp" />

            <!-- Bidirectional Arrow -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginHorizontal="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_left"
                    android:tint="?attr/colorSecondary"
                    android:layout_marginEnd="2dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    android:tint="?attr/colorSecondary"
                    android:layout_marginStart="2dp" />
            </LinearLayout>

            <!-- Leet Mode Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonLeetSelector"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Simple Leet"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:fontFamily="@font/raleway"
                android:textAllCaps="false"
                android:minHeight="48dp"
                app:strokeColor="?attr/colorSecondary"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_marginStart="8dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>