<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:name=".LeetSpeakApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name_short"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LeetspeakGenerator"
        android:localeConfig="@xml/locales_config"
        tools:targetApi="34">

        <!-- 🏠 MAIN COMPOSE ACTIVITY -->
        <activity
            android:name=".ui.ComposeMainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.LeetspeakGenerator">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- 🔗 Deeplink: leetspeak://translate?text=hello -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="leetspeak" android:host="translate" />
            </intent-filter>
        </activity>

        <!-- ⚙️ SETTINGS ACTIVITY -->
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:label="@string/settings"
            android:theme="@style/Theme.LeetspeakGenerator"
            android:parentActivityName=".ui.ComposeMainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".ui.ComposeMainActivity" />
        </activity>

        <!-- 🌍 LOCALE METADATA SERVICE (für API < 33) -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

        <!-- 📱 LAUNCH-WIDGET: kein Übersetzungs-Widget mehr, nur ein schneller
             Öffnen-Button fürs Homescreen -->
        <receiver
            android:name=".widget.LeetLaunchWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_open_app">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/leet_launch_widget_info" />
        </receiver>

        <!-- ⌨️ LEETSPEAK-TASTATUR (IME): übersetzt live beim Tippen, in jeder App -->
        <service
            android:name=".keyboard.LeetKeyboardService"
            android:exported="true"
            android:label="@string/settings_keyboard_title"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

    </application>

</manifest>